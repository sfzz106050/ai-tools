.container{padding:20rpx 30rpx}
.header{text-align:center;padding:40rpx 0 30rpx}
.title{font-size:36rpx;font-weight:800;color:#e2b04a}
.sub{font-size:24rpx;color:#999;display:block;margin-top:8rpx}
.section{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx}
.section-title{font-size:28rpx;font-weight:700;color:#333;margin-bottom:16rpx;display:block}
.input{border:1px solid #e5e5e5;border-radius:10rpx;padding:16rpx 20rpx;font-size:28rpx;margin-bottom:12rpx;background:#fafafa}
.picker{border:1px solid #e5e5e5;border-radius:10rpx;padding:16rpx 20rpx;font-size:28rpx;margin-bottom:12rpx;background:#fafafa;color:#888}
.btn{background:linear-gradient(135deg,#e2b04a,#c8963e);color:#fff;border-radius:14rpx;padding:24rpx;text-align:center;font-size:32rpx;font-weight:700;margin:20rpx 0}
.result{background:#1a1a2e;border-radius:16rpx;padding:30rpx;margin-top:20rpx}
.result-title{color:#e2b04a;font-size:30rpx;font-weight:700;display:block;margin-bottom:16rpx}
.result-row{padding:12rpx 0;border-bottom:1px solid rgba(255,255,255,.08);color:#c9d1d9;font-size:26rpx}
